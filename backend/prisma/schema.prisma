
generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "linux-musl", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Customer {
  id              String    @id @default(uuid())
  externalId      String?   @unique @map("external_id")
  name            String
  email           String    @unique
  phone           String?
  channel         String    @default("email") // preferred channel
  city            String?
  country         String    @default("IN")
  tags            String[]  @default([])
  totalSpend      Float     @default(0) @map("total_spend")
  orderCount      Int       @default(0) @map("order_count")
  lastOrderAt     DateTime? @map("last_order_at")
  firstOrderAt    DateTime? @map("first_order_at")
  avgOrderValue   Float     @default(0) @map("avg_order_value")
  isActive        Boolean   @default(true) @map("is_active")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  orders          Order[]
  communications  Communication[]
  segmentMembers  SegmentMember[]

  @@index([email])
  @@index([totalSpend])
  @@index([lastOrderAt])
  @@index([orderCount])

  @@map("customers")
}

model Order {
  id          String    @id @default(uuid())
  customerId  String    @map("customer_id")
  externalId  String?   @unique @map("external_id")
  amount      Float
  status      String    @default("completed") // pending, completed, cancelled, refunded
  channel     String    @default("online") // online, offline, app
  category    String?
  items       Json      @default("[]")
  orderedAt   DateTime  @default(now()) @map("ordered_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([customerId])
  @@index([orderedAt])
  @@index([amount])

  @@map("orders")
}

model Segment {
  id              String    @id @default(uuid())
  name            String
  description     String?
  rules           Json      // { operator: 'AND'|'OR', conditions: [...] }
  aiGenerated     Boolean   @default(false) @map("ai_generated")
  aiPrompt        String?   @map("ai_prompt")
  customerCount   Int       @default(0) @map("customer_count")
  isActive        Boolean   @default(true) @map("is_active")
  lastCalculated  DateTime? @map("last_calculated")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  members         SegmentMember[]
  campaigns       Campaign[]

  @@index([createdAt])

  @@map("segments")
}

model SegmentMember {
  id          String    @id @default(uuid())
  segmentId   String    @map("segment_id")
  customerId  String    @map("customer_id")
  addedAt     DateTime  @default(now()) @map("added_at")

  segment     Segment   @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  customer    Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@unique([segmentId, customerId])
  @@index([segmentId])
  @@index([customerId])

  @@map("segment_members")
}

model Campaign {
  id              String    @id @default(uuid())
  name            String
  description     String?
  segmentId       String    @map("segment_id")
  channel         String    // whatsapp, sms, email, rcs
  messageTemplate String    @map("message_template") // may include {{name}}, {{discount}}, etc.
  aiGenerated     Boolean   @default(false) @map("ai_generated")
  aiPrompt        String?   @map("ai_prompt")
  status          String    @default("draft") // draft, scheduled, running, completed, paused, failed
  templates       Json?     // Stores { whatsapp, email, sms, rcs } versions
  scheduledAt     DateTime? @map("scheduled_at")
  startedAt       DateTime? @map("started_at")
  completedAt     DateTime? @map("completed_at")
  totalRecipients  Int       @default(0) @map("total_recipients")
  totalSent        Int       @default(0) @map("total_sent")
  totalDelivered  Int       @default(0) @map("total_delivered")
  totalFailed     Int       @default(0) @map("total_failed")
  totalOpened     Int       @default(0) @map("total_opened")
  totalClicked    Int       @default(0) @map("total_clicked")
  totalRead       Int       @default(0) @map("total_read")
  totalConverted  Int       @default(0) @map("total_converted")
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  segment         Segment   @relation(fields: [segmentId], references: [id], onDelete: Cascade)
  communications  Communication[]

  @@index([status])
  @@index([segmentId])
  @@index([createdAt])

  @@map("campaigns")
}

model Communication {
  id              String    @id @default(uuid())
  campaignId      String    @map("campaign_id")
  customerId      String    @map("customer_id")
  channel         String    // whatsapp, sms, email, rcs
  message         String
  status          String    @default("queued") // queued, sent, delivered, failed, opened, read, clicked, converted
  externalMsgId   String?   @map("external_msg_id") // from channel service
  sentAt          DateTime? @map("sent_at")
  deliveredAt     DateTime? @map("delivered_at")
  openedAt        DateTime? @map("opened_at")
  readAt          DateTime? @map("read_at")
  clickedAt       DateTime? @map("clicked_at")
  convertedAt     DateTime? @map("converted_at")
  failedAt        DateTime? @map("failed_at")
  failureReason   String?   @map("failure_reason")
  retryCount      Int       @default(0) @map("retry_count")
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  campaign        Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer        Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([campaignId])
  @@index([customerId])
  @@index([status])
  @@index([externalMsgId])

  @@map("communications")
}

model AiConversation {
  id          String    @id @default(uuid())
  sessionId   String    @map("session_id")
  role        String    // user | assistant
  content     String
  metadata    Json      @default("{}")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([sessionId])
  @@index([createdAt])

  @@map("ai_conversations")
}
